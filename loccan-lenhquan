<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Đăng Nhập – Bản Luận Căn Số</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:      #1a1208;
    --gold:     #c8922a;
    --gold-lt:  #e6b84a;
    --parch:    #faf3e8;
    --parch-dk: #f0e4cc;
    --smoke:    #7a6e60;
    --rule:     rgba(200,146,42,0.3);
    --red-err:  #f87171;
  }

  body {
    background: var(--ink);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    padding: 24px;
    position: relative;
    overflow: hidden;
  }

  /* ambient glow */
  body::before {
    content: '';
    position: fixed;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(200,146,42,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  /* pattern overlay */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23c8922a' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* ── CARD ── */
  .login-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 400px;
    background: linear-gradient(160deg, #2a1a00 0%, #1a0e00 100%);
    border: 1px solid var(--rule);
    border-radius: 20px;
    padding: 44px 40px 40px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.6);
  }

  /* logo / icon */
  .logo {
    text-align: center;
    margin-bottom: 28px;
  }
  .logo-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px; height: 64px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,146,42,0.2), rgba(200,146,42,0.05));
    border: 1px solid var(--rule);
    font-size: 30px;
    margin-bottom: 14px;
    animation: pulse 3s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(200,146,42,0.2); }
    50%      { box-shadow: 0 0 0 12px rgba(200,146,42,0); }
  }
  .logo h1 {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--gold-lt);
    line-height: 1.3;
  }
  .logo p {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--smoke);
    margin-top: 4px;
  }

  /* divider */
  .divider {
    display: flex; align-items: center; gap: 10px;
    margin: 24px 0 22px;
  }
  .divider span { flex: 1; height: 1px; background: var(--rule); }
  .divider em { color: var(--gold); font-style: normal; font-size: 14px; }

  /* ── FORM ── */
  .field { margin-bottom: 18px; }

  .field label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--smoke);
    margin-bottom: 7px;
  }

  .input-wrap {
    position: relative;
  }
  .input-wrap .icon {
    position: absolute;
    left: 14px; top: 50%;
    transform: translateY(-50%);
    font-size: 15px;
    pointer-events: none;
    opacity: 0.5;
  }

  .field input {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(200,146,42,0.2);
    border-radius: 10px;
    padding: 12px 14px 12px 40px;
    color: var(--parch);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .field input::placeholder { color: var(--smoke); }
  .field input:focus {
    border-color: var(--gold);
    background: rgba(200,146,42,0.06);
  }
  .field input.error {
    border-color: var(--red-err);
  }

  /* toggle password */
  .toggle-pw {
    position: absolute;
    right: 13px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    cursor: pointer;
    color: var(--smoke);
    font-size: 16px;
    padding: 2px;
    line-height: 1;
  }
  .toggle-pw:hover { color: var(--gold-lt); }

  /* error message */
  .err-msg {
    font-size: 12px;
    color: var(--red-err);
    margin-top: 6px;
    display: none;
  }
  .err-msg.show { display: block; }

  /* alert box */
  .alert {
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 13px;
    margin-bottom: 18px;
    display: none;
  }
  .alert.show { display: flex; align-items: flex-start; gap: 10px; }
  .alert.err  { background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.35); color: var(--red-err); }
  .alert.ok   { background: rgba(74,222,128,0.12); border: 1px solid rgba(74,222,128,0.35); color: #4ade80; }

  /* submit button */
  .btn-login {
    width: 100%;
    background: linear-gradient(135deg, #c8922a 0%, #a86f1a 100%);
    color: var(--ink);
    border: none;
    border-radius: 10px;
    padding: 13px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: opacity 0.2s, transform 0.15s;
    margin-top: 4px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .btn-login:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .btn-login:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

  /* spinner */
  .spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(26,18,8,0.3);
    border-top-color: var(--ink);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* welcome screen (post-login) */
  .welcome {
    display: none;
    text-align: center;
  }
  .welcome .w-icon { font-size: 48px; margin-bottom: 16px; }
  .welcome h2 {
    font-family: 'Playfair Display', serif;
    color: var(--gold-lt);
    font-size: 22px;
    margin-bottom: 8px;
  }
  .welcome p { color: var(--smoke); font-size: 14px; line-height: 1.6; }
  .welcome .user-email {
    display: inline-block;
    margin: 14px 0;
    background: rgba(200,146,42,0.1);
    border: 1px solid var(--rule);
    border-radius: 20px;
    padding: 6px 16px;
    font-size: 13px;
    color: var(--gold-lt);
  }
  .btn-logout {
    margin-top: 20px;
    background: none;
    border: 1px solid var(--rule);
    color: var(--smoke);
    border-radius: 8px;
    padding: 9px 22px;
    font-size: 13px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-logout:hover { border-color: var(--gold); color: var(--gold-lt); }

  @media (max-width: 440px) {
    .login-card { padding: 36px 24px 32px; }
  }
</style>
</head>
<body>

<div class="login-card">

  <!-- LOGO -->
  <div class="logo">
    <div class="logo-icon">🪷</div>
    <h1>Bản Luận Căn Số</h1>
    <p>Đăng nhập để tiếp tục</p>
  </div>

  <!-- FORM -->
  <div id="formView">
    <div class="divider"><span></span><em>✦</em><span></span></div>

    <!-- Alert lỗi chung -->
    <div class="alert err" id="alertErr">
      <span>⚠</span>
      <span id="alertErrMsg">Sai email hoặc mật khẩu.</span>
    </div>

    <!-- Email -->
    <div class="field">
      <label>Email</label>
      <div class="input-wrap">
        <span class="icon">✉</span>
        <input type="email" id="email" placeholder="email@example.com" autocomplete="email" />
      </div>
      <p class="err-msg" id="emailErr">Vui lòng nhập email hợp lệ.</p>
    </div>

    <!-- Mật khẩu -->
    <div class="field">
      <label>Mật khẩu</label>
      <div class="input-wrap">
        <span class="icon">🔒</span>
        <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" />
        <button class="toggle-pw" type="button" id="togglePw" title="Hiện / ẩn mật khẩu">👁</button>
      </div>
      <p class="err-msg" id="passErr">Mật khẩu cần ít nhất 6 ký tự.</p>
    </div>

    <button class="btn-login" id="btnLogin" type="button" onclick="doLogin()">
      <div class="spinner" id="spinner"></div>
      <span id="btnText">Đăng nhập</span>
    </button>
  </div>

  <!-- WELCOME (sau đăng nhập) -->
  <div class="welcome" id="welcomeView">
    <div class="w-icon">✨</div>
    <h2>Chào mừng trở lại!</h2>
    <p>Bạn đã đăng nhập thành công vào hệ thống.</p>
    <div class="user-email" id="userEmail"></div>
    <p style="font-size:13px; color:var(--smoke);">Quan Hoàng Bảy phù hộ cho hành trình của bạn 🙏</p>
    <button class="btn-logout" onclick="doLogout()">Đăng xuất</button>
  </div>

</div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import {
    getAuth,
    signInWithEmailAndPassword,
    signOut,
    onAuthStateChanged
  } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

  const firebaseConfig = {
    apiKey: "AIzaSyA-G3BfucCstuMlQDKDsQVu3daQ854tuCQ",
    authDomain: "csdl-login.firebaseapp.com",
    databaseURL: "https://csdl-login-default-rtdb.firebaseio.com",
    projectId: "csdl-login",
    storageBucket: "csdl-login.firebasestorage.app",
    messagingSenderId: "1036020118468",
    appId: "1:1036020118468:web:6fe17be2597334f9986a91",
    measurementId: "G-WGC5R6VVBK"
  };

  const app  = initializeApp(firebaseConfig);
  const auth = getAuth(app);

  // toggle password visibility
  document.getElementById('togglePw').addEventListener('click', () => {
    const pw = document.getElementById('password');
    pw.type = pw.type === 'password' ? 'text' : 'password';
  });

  // Enter key support
  document.getElementById('password').addEventListener('keydown', e => {
    if (e.key === 'Enter') window.doLogin();
  });
  document.getElementById('email').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('password').focus();
  });

  // Auth state listener
  onAuthStateChanged(auth, user => {
    if (user) showWelcome(user.email);
    else showForm();
  });

  function showWelcome(email) {
    document.getElementById('formView').style.display = 'none';
    document.getElementById('welcomeView').style.display = 'block';
    document.getElementById('userEmail').textContent = email;
  }

  function showForm() {
    document.getElementById('formView').style.display = 'block';
    document.getElementById('welcomeView').style.display = 'none';
  }

  function setLoading(on) {
    document.getElementById('btnLogin').disabled = on;
    document.getElementById('spinner').style.display = on ? 'block' : 'none';
    document.getElementById('btnText').textContent = on ? 'Đang đăng nhập…' : 'Đăng nhập';
  }

  function clearErrors() {
    ['emailErr','passErr'].forEach(id => document.getElementById(id).classList.remove('show'));
    ['email','password'].forEach(id => document.getElementById(id).classList.remove('error'));
    const a = document.getElementById('alertErr');
    a.classList.remove('show');
  }

  function firebaseErrMsg(code) {
    const map = {
      'auth/user-not-found':       'Không tìm thấy tài khoản với email này.',
      'auth/wrong-password':       'Mật khẩu không đúng. Vui lòng thử lại.',
      'auth/invalid-credential':   'Email hoặc mật khẩu không chính xác.',
      'auth/invalid-email':        'Địa chỉ email không hợp lệ.',
      'auth/too-many-requests':    'Quá nhiều lần thử. Vui lòng đợi một chút rồi thử lại.',
      'auth/network-request-failed': 'Lỗi kết nối mạng. Vui lòng kiểm tra internet.',
    };
    return map[code] || 'Đăng nhập thất bại. Vui lòng thử lại.';
  }

  window.doLogin = async function () {
    clearErrors();
    const email = document.getElementById('email').value.trim();
    const pass  = document.getElementById('password').value;
    let valid = true;

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      document.getElementById('emailErr').classList.add('show');
      document.getElementById('email').classList.add('error');
      valid = false;
    }
    if (pass.length < 6) {
      document.getElementById('passErr').classList.add('show');
      document.getElementById('password').classList.add('error');
      valid = false;
    }
    if (!valid) return;

    setLoading(true);
    try {
      await signInWithEmailAndPassword(auth, email, pass);
      // onAuthStateChanged sẽ xử lý chuyển màn hình
    } catch (err) {
      const msg = firebaseErrMsg(err.code);
      document.getElementById('alertErrMsg').textContent = msg;
      document.getElementById('alertErr').classList.add('show');
      setLoading(false);
    }
  };

  window.doLogout = async function () {
    await signOut(auth);
  };
</script>
</body>
</html>
