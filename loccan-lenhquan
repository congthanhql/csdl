<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

  const firebaseConfig = {
    apiKey: "AIzaSyA-G3BfucCstuMlQDKDsQVu3daQ854tuCQ",
    authDomain: "csdl-login.firebaseapp.com",
    databaseURL: "https://csdl-login-default-rtdb.firebaseio.com",
    projectId: "csdl-login",
    storageBucket: "csdl-login.firebasestorage.app",
    messagingSenderId: "1036020118468",
    appId: "1:1036020118468:web:6fe17be2597334f9986a91",
    measurementId: "G-WGC5R6VVBK"
  };

  const app  = initializeApp(firebaseConfig);
  const auth = getAuth(app);

  // toggle password
  document.getElementById('togglePw').addEventListener('click', () => {
    const pw = document.getElementById('password');
    pw.type = pw.type === 'password' ? 'text' : 'password';
  });

  // enter key
  document.getElementById('email').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('password').focus(); });
  document.getElementById('password').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });

  // auth state
  onAuthStateChanged(auth, user => {
    if (user) showMain(user.email);
    else showLogin();
  });

  function showLogin() {
    document.getElementById('loginPage').style.display = 'flex';
    document.getElementById('mainPage').style.display = 'none';
    document.getElementById('btnText').textContent = 'Đăng nhập';
    document.getElementById('btnLogin').disabled = false;
    document.getElementById('spinner').style.display = 'none';
  }

  function showMain(email) {
    document.getElementById('loginPage').style.display = 'none';
    document.getElementById('mainPage').style.display = 'block';
    document.getElementById('userEmail').textContent = email;
    document.getElementById('userAvatar').textContent = email.charAt(0).toUpperCase();
    window.scrollTo(0, 0);
  }

  function clearErrors() {
    ['emailErr','passErr'].forEach(id => document.getElementById(id).classList.remove('show'));
    ['email','password'].forEach(id => document.getElementById(id).classList.remove('err-input'));
    const a = document.getElementById('alertErr');
    a.classList.remove('show');
  }

  function errMsg(code) {
    return ({
      'auth/user-not-found':        'Không tìm thấy tài khoản với email này.',
      'auth/wrong-password':        'Mật khẩu không đúng. Vui lòng thử lại.',
      'auth/invalid-credential':    'Email hoặc mật khẩu không chính xác.',
      'auth/invalid-email':         'Địa chỉ email không hợp lệ.',
      'auth/too-many-requests':     'Quá nhiều lần thử. Vui lòng đợi rồi thử lại.',
      'auth/network-request-failed':'Lỗi kết nối mạng. Kiểm tra internet và thử lại.',
    })[code] || 'Đăng nhập thất bại. Vui lòng thử lại.';
  }

  async function doLogin() {
    clearErrors();
    const email = document.getElementById('email').value.trim();
    const pass  = document.getElementById('password').value;
    let ok = true;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      document.getElementById('emailErr').classList.add('show');
      document.getElementById('email').classList.add('err-input');
      ok = false;
    }
    if (pass.length < 6) {
      document.getElementById('passErr').classList.add('show');
      document.getElementById('password').classList.add('err-input');
      ok = false;
    }
    if (!ok) return;

    document.getElementById('btnLogin').disabled = true;
    document.getElementById('spinner').style.display = 'block';
    document.getElementById('btnText').textContent = 'Đang đăng nhập…';

    try {
      await signInWithEmailAndPassword(auth, email, pass);
    } catch (e) {
      document.getElementById('alertErrMsg').textContent = errMsg(e.code);
      document.getElementById('alertErr').classList.add('show');
      document.getElementById('btnLogin').disabled = false;
      document.getElementById('spinner').style.display = 'none';
      document.getElementById('btnText').textContent = 'Đăng nhập';
    }
  }

  document.getElementById('btnLogin').addEventListener('click', doLogin);
  document.getElementById('btnLogout').addEventListener('click', () => signOut(auth));
</script>
