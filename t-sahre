const suitColors={major:'#7b6ee8',wands:'#e8634c',cups:'#4e9de8',swords:'#8fa0b0',pentacles:'#f4a836'};
let tarotFilter='all';

function renderTarot(){
  const q=document.getElementById('tarot-search').value.toLowerCase();
  const grid=document.getElementById('tarot-grid');
  const filtered=tarotCards.filter(c=>
    (tarotFilter==='all'||c.suit===tarotFilter)&&
    (!q||c.name.toLowerCase().includes(q)||c.nameVi.toLowerCase().includes(q)||c.keywords.toLowerCase().includes(q))
  );
  grid.innerHTML=filtered.length?filtered.map(c=>`
    <div class="card-item ${c.suit}" onclick='openTarotModal(${JSON.stringify(c).replace(/'/g,"&#39;")})'>
      <div class="card-suit">${c.number}</div>
      <div class="card-name">${c.name}</div>
      <div class="card-name-vi">${c.nameVi}</div>
      <div class="card-keys">${c.keywords}</div>
    </div>`).join(''):'<div class="empty" style="grid-column:1/-1"><p>Không tìm thấy</p></div>';
}

function openTarotModal(c){
  const col=suitColors[c.suit]||'var(--gold)';
  openModal(`
    <div class="modal-num" style="color:${col}">${c.number} · ${c.suit==='major'?'Major Arcana':c.suit.charAt(0).toUpperCase()+c.suit.slice(1)}</div>
    <div class="modal-title">${c.name}</div>
    <div class="modal-vi" style="color:${col}">${c.nameVi}</div>
    <div class="modal-keys">${c.keywords}</div>
    <div class="modal-section"><h4>⬆ Nghĩa xuôi</h4><p>${c.uprightMeaning}</p></div>
    <div class="modal-section"><h4>⬇ Nghĩa ngược</h4><p>${c.reversedMeaning}</p></div>
    <div class="modal-meta">
      <div class="meta-pill">Nguyên tố<span>${c.element}</span></div>
      <div class="meta-pill">Chiêm tinh<span>${c.astrology}</span></div>
    </div>`);
}

document.getElementById('tarot-search').addEventListener('input',renderTarot);
document.querySelectorAll('#tarot-filters .chip').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('#tarot-filters .chip').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');tarotFilter=btn.dataset.tf;renderTarot();
  });
});

