<script>
/* ═══════════════════════════════════
   FIREBASE
═══════════════════════════════════ */
const firebaseConfig={
  apiKey:"AIzaSyDtAU-Iqn-u39_mgkxRZ3fIF_Kyxqn-Gyg",
  authDomain:"csdl-bio.firebaseapp.com",
  databaseURL:"https://csdl-bio-default-rtdb.firebaseio.com",
  projectId:"csdl-bio",
  storageBucket:"csdl-bio.firebasestorage.app",
  messagingSenderId:"568258817515",
  appId:"1:568258817515:web:e5b7d7a0b42b25baa63dae"
};
firebase.initializeApp(firebaseConfig);
const db=firebase.database();
const auth=firebase.auth();

const ADMIN_EMAIL='bioverify@googlegroups.com';
const SUPERUSER_EMAIL='congthanh.edu.vn';

// Username → email map (for username login)
const USERNAME_MAP={'admin':'bioverify@googlegroups.com','thanh':'congthanh.edu.vn'};

let currentUser=null,currentAccess=null,isAdmin=false;

/* ═══════════════════════════════════
   THEME
═══════════════════════════════════ */
function toggleTheme(){
  const html=document.documentElement;
  const isDark=html.getAttribute('data-theme')==='dark';
  const next=isDark?'light':'dark';
  html.setAttribute('data-theme',next);
  const icon=isDark?'🌙':'☀️';
  document.querySelectorAll('#theme-btn,#theme-btn2,.theme-fab').forEach(b=>{if(b)b.textContent=icon});
  localStorage.setItem('theme',next);
}
(function(){
  const saved=localStorage.getItem('theme')||'dark';
  document.documentElement.setAttribute('data-theme',saved);
  const icon=saved==='dark'?'☀️':'🌙';
  document.querySelectorAll('#theme-btn,#theme-btn2,.theme-fab').forEach(b=>{if(b)b.textContent=icon});
})();

/* ═══════════════════════════════════
   SCREENS
═══════════════════════════════════ */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  const s=document.getElementById('screen-'+id);
  if(s)s.classList.add('active');
  const saved=localStorage.getItem('theme')||'dark';
  const icon=saved==='dark'?'☀️':'🌙';
  document.querySelectorAll('#theme-btn,#theme-btn2,.theme-fab').forEach(b=>{if(b)b.textContent=icon});
}

/* ═══════════════════════════════════
   TOAST
═══════════════════════════════════ */
let toastTimer;
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='toast '+(type||'');t.classList.add('show');
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),3000);
}

/* ═══════════════════════════════════
   LOGIN (email OR username)
═══════════════════════════════════ */
async function doLogin(){
  let input=document.getElementById('l-user').value.trim();
  const pass=document.getElementById('l-pass').value;
  const btn=document.getElementById('login-btn');
  const err=document.getElementById('l-err');
  err.style.display='none';
  if(!input||!pass){err.textContent='⚠ Vui lòng nhập đầy đủ thông tin';err.style.display='block';return;}

  // Resolve username → email
  let email=input;
  if(!input.includes('@')){
    const mapped=USERNAME_MAP[input.toLowerCase()];
    if(mapped){email=mapped;}
    else{
      try{
        const snap=await db.ref('usernames/'+input.toLowerCase()).once('value');
        if(snap.val()){email=snap.val();}
        else{err.textContent='⚠ Tên đăng nhập không tồn tại';err.style.display='block';return;}
      }catch(e){
        err.textContent='⚠ Không thể xác minh tên đăng nhập';err.style.display='block';return;
      }
    }
  }

  btn.textContent='Đang đăng nhập...';btn.disabled=true;
  try{
    await auth.signInWithEmailAndPassword(email,pass);
  }catch(e){
    err.textContent='⚠ Sai tài khoản hoặc mật khẩu';err.style.display='block';
    btn.textContent='Đăng nhập';btn.disabled=false;
  }
}
document.getElementById('l-pass').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin()});
document.getElementById('l-user').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('l-pass').focus()});

async function doLogout(){
  await auth.signOut();
  currentUser=null;currentAccess=null;isAdmin=false;
  document.getElementById('login-btn').textContent='Đăng nhập';
  document.getElementById('login-btn').disabled=false;
  showScreen('login');
}

/* ═══════════════════════════════════
   AUTH STATE
═══════════════════════════════════ */
auth.onAuthStateChanged(async user=>{
  if(!user){showScreen('login');return;}
  currentUser=user;
  const email=user.email;

  if(email===ADMIN_EMAIL){isAdmin=true;showScreen('admin');loadAdminData();return;}
  if(email===SUPERUSER_EMAIL){currentAccess='all';showScreen('app');renderAll();return;}

  const snap=await db.ref('users/'+sanitizeEmail(email)).once('value');
  const d=snap.val();
  if(!d){
    // Tự động tạo tài khoản với full access, không cần xét duyệt
    await db.ref('users/'+sanitizeEmail(email)).set({email,status:'approved',access:'all',createdAt:Date.now()});
    currentAccess='all';showScreen('app');renderAll();return;
  }
  if(d.status==='denied'){document.getElementById('error-desc').textContent='Tài khoản đã bị từ chối. Liên hệ admin.';showScreen('error');return;}
  if(d.status==='locked'){document.getElementById('error-desc').textContent='Tài khoản đã bị khóa. Liên hệ admin.';showScreen('error');return;}
  currentAccess=d.access||'all';
  showScreen('app');renderAll();
});

function sanitizeEmail(e){return e.replace(/\./g,'_').replace(/@/g,'_at_')}

/* ═══════════════════════════════════
   PANEL SWITCHING
═══════════════════════════════════ */
function switchPanel(name,el){
  if(!canAccess(name)){showLockedPanel(name);
    document.querySelectorAll('.nav-item,.sidebar-item').forEach(n=>n.classList.remove('active'));
    document.querySelectorAll(`[data-panel="${name}"]`).forEach(n=>n.classList.add('active'));
    return;
  }
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item,.sidebar-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  document.querySelectorAll(`[data-panel="${name}"]`).forEach(n=>n.classList.add('active'));
}
function canAccess(n){
  if(currentAccess==='all')return true;
  if(n==='yesno')return currentAccess==='tay'||currentAccess==='all';
  return currentAccess===n;
}
function showLockedPanel(name){
  const panel=document.getElementById('panel-'+name);
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  panel.classList.add('active');
  panel.innerHTML=`<div class="locked-panel"><div class="lock-icon">🔒</div><p>Bạn không có quyền truy cập mục này.<br>Liên hệ admin để mở khóa.</p></div>`;
}

