function loadAdminData(){
  db.ref('users').on('value',snap=>{renderAdminUsers(snap.val()||{})});
}
function renderAdminUsers(users){
  const all=Object.values(users);
  const uList=document.getElementById('users-list');
  uList.innerHTML=all.length?all.map(u=>userRowHTML(u)).join(''):'<div class="empty"><div class="empty-icon">👤</div><p>Chưa có người dùng</p></div>';
}
function userRowHTML(u){
  const sL={pending:'Chờ duyệt',approved:'Đã duyệt',denied:'Từ chối',locked:'Bị khóa'};
  const sC={pending:'status-pending',approved:'status-approved',denied:'status-denied',locked:'status-locked'};
  const aL={all:'Full Access',tay:'Bài Tây',tarot:'Tarot',lenormand:'Lenormand',none:'Chưa rõ'};
  const key=sanitizeEmail(u.email);
  let actions='';
  if(u.status==='approved'){
    actions=`<button class="act-btn lock" onclick="adminLock('${key}')">🔒 Khóa</button>
             <button class="act-btn deny" onclick="adminDeny('${key}')">✗ Từ chối</button>
             <button class="act-btn del" onclick="adminDelete('${key}')">🗑</button>`;
  }else{
    actions=`<button class="act-btn approve" onclick="adminRestore('${key}','${u.email}')">↩ Mở khóa</button>
             <button class="act-btn del" onclick="adminDelete('${key}')">🗑</button>`;
  }
  return `<div class="user-row">
    <div>
      <div class="user-email">${u.email}</div>
      <div class="user-meta">
        <span class="status-badge ${sC[u.status]||'status-approved'}">${sL[u.status]||'Đã duyệt'}</span>
        <span class="user-meta-text">Quyền: ${aL[u.access]||'Full'}</span>
      </div>
    </div>
    <div class="user-actions">
      <button class="act-btn" onclick="adminEditAccess('${key}','${u.email}','${u.access||'all'}')">✏</button>
      ${actions}
    </div>
  </div>`;
}
async function adminRestore(key,email){
  const access=await promptAccess();if(!access)return;
  await db.ref('users/'+key).update({status:'approved',access});
  showToast('✅ Đã mở khóa: '+email,'success');
}
async function adminDeny(key){
  if(!confirm('Từ chối tài khoản này?'))return;
  await db.ref('users/'+key).update({status:'denied'});showToast('Đã từ chối','error');
}
async function adminLock(key){
  await db.ref('users/'+key).update({status:'locked'});showToast('Đã khóa tài khoản');
}
async function adminDelete(key){
  if(!confirm('Xóa tài khoản này? Không thể hoàn tác!'))return;
  await db.ref('users/'+key).remove();showToast('Đã xóa tài khoản');
}
async function adminEditAccess(key,email,cur){
  openModal(`<div class="modal-badge" style="color:var(--gold)">Chỉnh quyền</div>
    <div class="modal-title" style="font-size:20px;margin-bottom:16px">${email}</div>
    <div class="modal-divider"></div>
    <select class="admin-select" id="access-picker" style="margin:16px 0">
      <option value="all" ${cur==='all'?'selected':''}>🌟 Full Access</option>
      <option value="tay" ${cur==='tay'?'selected':''}>♠ Bài Tây only</option>
      <option value="tarot" ${cur==='tarot'?'selected':''}>🔮 Tarot only</option>
      <option value="lenormand" ${cur==='lenormand'?'selected':''}>🌿 Lenormand only</option>
    </select>
    <button class="btn-small" style="width:100%" onclick="saveAccess('${key}')">Lưu thay đổi</button>`);
}
async function saveAccess(key){
  const val=document.getElementById('access-picker').value;
  await db.ref('users/'+key).update({access:val});
  closeModal();showToast('✅ Đã cập nhật quyền','success');
}
async function adminCreateUser(){
  const email=document.getElementById('new-email').value.trim();
  const pass=document.getElementById('new-pass').value;
  const access=document.getElementById('new-access').value;
  if(!email||!pass){showToast('Vui lòng điền đủ thông tin','error');return;}
  try{
    await auth.createUserWithEmailAndPassword(email,pass);
    await db.ref('users/'+sanitizeEmail(email)).set({email,status:'approved',access,createdAt:Date.now()});
    await auth.signInWithEmailAndPassword(ADMIN_EMAIL,'Thanh123@');
    document.getElementById('new-email').value='';document.getElementById('new-pass').value='';
    showToast('✅ Đã tạo: '+email,'success');
  }catch(e){showToast('Lỗi: '+e.message,'error');}
}
function promptAccess(){
  return new Promise(resolve=>{
    openModal(`<div class="modal-badge" style="color:var(--gold)">Chọn quyền truy cập</div>
      <div class="modal-title" style="font-size:22px;margin-bottom:16px">Quyền truy cập</div>
      <div class="modal-divider"></div>
      <select class="admin-select" id="prompt-access" style="margin:16px 0">
        <option value="all">🌟 Full Access — Tất cả</option>
        <option value="tay">♠ Bài Tây only</option>
        <option value="tarot">🔮 Tarot only</option>
        <option value="lenormand">🌿 Lenormand only</option>
      </select>
      <button class="btn-small" style="width:100%" onclick="const v=document.getElementById('prompt-access').value;closeModal();window._par(v);">Xác nhận</button>`);
    window._par=resolve;
  });
}

