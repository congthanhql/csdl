<script>
/* ══════════════════════════════════════
   FIREBASE INIT
══════════════════════════════════════ */
const firebaseConfig={
  apiKey:"AIzaSyDtAU-Iqn-u39_mgkxRZ3fIF_Kyxqn-Gyg",
  authDomain:"csdl-bio.firebaseapp.com",
  databaseURL:"https://csdl-bio-default-rtdb.firebaseio.com",
  projectId:"csdl-bio",
  storageBucket:"csdl-bio.firebasestorage.app",
  messagingSenderId:"568258817515",
  appId:"1:568258817515:web:e5b7d7a0b42b25baa63dae",
  measurementId:"G-PL5TNK82S6"
};
firebase.initializeApp(firebaseConfig);
const db=firebase.database();
const auth=firebase.auth();

// Admin email
const ADMIN_EMAIL='bioverify@gmail.com';
const SUPERUSER_EMAIL='congthanh.edu.vn';

// Member code → access map (these are the codes users enter after login)
const MEMBER_CODES={
  'L9pHo3':'tay',
  'CTEDU':'tarot',
  'T-SHARE':'lenormand',
};

let currentUser=null;
let currentAccess=null; // 'all','tay','tarot','lenormand'
let isAdmin=false;

/* ══════════════════════════════════════
   THEME
══════════════════════════════════════ */
function toggleTheme(){
  const html=document.documentElement;
  const isDark=html.getAttribute('data-theme')==='dark';
  html.setAttribute('data-theme',isDark?'light':'dark');
  document.querySelectorAll('#theme-btn,.theme-toggle-login').forEach(b=>b.textContent=isDark?'🌙':'☀️');
  localStorage.setItem('theme',isDark?'light':'dark');
}
(function(){
  const saved=localStorage.getItem('theme')||'dark';
  document.documentElement.setAttribute('data-theme',saved);
  document.querySelectorAll('#theme-btn,.theme-toggle-login').forEach(b=>b.textContent=saved==='dark'?'☀️':'🌙');
})();

/* ══════════════════════════════════════
   SCREEN MANAGEMENT
══════════════════════════════════════ */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active')});
  const s=document.getElementById('screen-'+id);
  if(s)s.classList.add('active');
}

/* ══════════════════════════════════════
   TOAST
══════════════════════════════════════ */
let toastTimer;
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.className='toast '+(type?type:'');
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),2800);
}

/* ══════════════════════════════════════
   AUTH
══════════════════════════════════════ */
async function doLogin(){
  const email=document.getElementById('l-user').value.trim();
  const pass=document.getElementById('l-pass').value;
  const btn=document.getElementById('login-btn');
  const err=document.getElementById('l-err');
  err.style.display='none';
  btn.textContent='Đang đăng nhập...';btn.disabled=true;
  try{
    await auth.signInWithEmailAndPassword(email,pass);
  }catch(e){
    err.style.display='block';
    btn.textContent='Đăng nhập';btn.disabled=false;
  }
}
document.getElementById('l-pass').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin()});

async function doLogout(){
  await auth.signOut();
  currentUser=null;currentAccess=null;isAdmin=false;
  showScreen('login');
}

/* ══════════════════════════════════════
   FIREBASE AUTH STATE
══════════════════════════════════════ */
auth.onAuthStateChanged(async user=>{
  if(!user){showScreen('login');return;}
  currentUser=user;
  const email=user.email;

  // Admin
  if(email===ADMIN_EMAIL){
    isAdmin=true;
    showScreen('admin');
    loadAdminData();
    return;
  }

  // Super user (full access, no code needed)
  if(email===SUPERUSER_EMAIL){
    currentAccess='all';
    showScreen('app');
    renderAll();
    return;
  }

  // Check firebase for user record
  const snap=await db.ref('users/'+sanitizeEmail(email)).once('value');
  const userData=snap.val();

  if(!userData){
    // New user — create pending record
    await db.ref('users/'+sanitizeEmail(email)).set({
      email,status:'pending',access:'none',createdAt:Date.now(),memberCode:''
    });
    showScreen('pending');
    return;
  }

  if(userData.status==='denied'){
    document.getElementById('error-desc').textContent='Tài khoản của bạn đã bị từ chối. Liên hệ admin để biết thêm.';
    showScreen('error');return;
  }
  if(userData.status==='locked'){
    document.getElementById('error-desc').textContent='Tài khoản của bạn đã bị khóa. Liên hệ admin.';
    showScreen('error');return;
  }
  if(userData.status==='pending'){
    showScreen('pending');return;
  }
  if(userData.status==='approved'){
    currentAccess=userData.access||'none';
    // If no member code set yet, ask for code
    if(!userData.memberCode&&currentAccess==='none'){
      document.getElementById('code-user-email').textContent=email;
      showScreen('code');
    } else {
      showScreen('app');
      renderAll();
    }
    return;
  }

  // Default: show code screen
  document.getElementById('code-user-email').textContent=email;
  showScreen('code');
});

function sanitizeEmail(email){
  return email.replace(/\./g,'_').replace(/@/g,'_at_');
}

/* ══════════════════════════════════════
   MEMBER CODE
══════════════════════════════════════ */
async function submitMemberCode(){
  const code=document.getElementById('member-code-input').value.trim();
  const err=document.getElementById('code-err');
  err.style.display='none';

  const access=MEMBER_CODES[code];
  if(!access){err.style.display='block';return;}

  const email=currentUser.email;
  const key=sanitizeEmail(email);
  const snap=await db.ref('users/'+key).once('value');
  const existing=snap.val();

  await db.ref('users/'+key).set({
    email,
    status: existing&&existing.status==='approved'?'approved':'pending',
    access: existing&&existing.status==='approved'?(existing.access||access):access,
    memberCode:code,
    createdAt:existing?existing.createdAt:Date.now(),
    requestedAt:Date.now()
  });

  if(existing&&existing.status==='approved'){
    currentAccess=existing.access||access;
    showScreen('app');renderAll();
  } else {
    showScreen('pending');
  }
}

async function checkApprovalStatus(){
  const snap=await db.ref('users/'+sanitizeEmail(currentUser.email)).once('value');
  const d=snap.val();
  if(d&&d.status==='approved'){
    currentAccess=d.access||'none';
    showScreen('app');renderAll();
    showToast('✅ Đã được phê duyệt!','success');
  } else if(d&&d.status==='denied'){
    showScreen('error');
  } else {
    showToast('⏳ Vẫn đang chờ phê duyệt...','');
  }
}

/* ══════════════════════════════════════
   PANEL SWITCHING
══════════════════════════════════════ */
function switchPanel(name,el){
  // Check access
  const allowed=canAccess(name);
  if(!allowed){
    showLockedPanel(name);
    return;
  }
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  if(el)el.classList.add('active');
}

function canAccess(panelName){
  if(currentAccess==='all')return true;
  if(panelName==='yesno')return currentAccess==='tay'||currentAccess==='all';
  return currentAccess===panelName;
}

function showLockedPanel(name){
  const panel=document.getElementById('panel-'+name);
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  panel.classList.add('active');
  panel.innerHTML=`<div class="locked-panel"><div class="lock-icon">🔒</div><p>Bạn không có quyền truy cập mục này.<br>Liên hệ admin để mở khóa.</p></div>`;
}

/* ══════════════════════════════════════
   ADMIN FUNCTIONS
══════════════════════════════════════ */
function loadAdminData(){
  // Real-time listener
  db.ref('users').on('value',snap=>{
    const users=snap.val()||{};
    renderAdminUsers(users);
  });
}

function renderAdminUsers(users){
  const pending=[];const all=[];
  Object.values(users).forEach(u=>{
    all.push(u);
    if(u.status==='pending')pending.push(u);
  });
  document.getElementById('pending-count').textContent=pending.length;

  // Pending
  const pList=document.getElementById('pending-list');
  if(pending.length===0){
    pList.innerHTML='<div class="empty"><div class="empty-icon">✓</div><p>Không có yêu cầu nào</p></div>';
  } else {
    pList.innerHTML=pending.map(u=>userRowHTML(u,true)).join('');
  }

  // All users
  const uList=document.getElementById('users-list');
  if(all.length===0){
    uList.innerHTML='<div class="empty"><div class="empty-icon">👤</div><p>Chưa có người dùng</p></div>';
  } else {
    uList.innerHTML=all.map(u=>userRowHTML(u,false)).join('');
  }
}

function userRowHTML(u,compact){
  const statusLabel={pending:'Chờ duyệt',approved:'Đã duyệt',denied:'Từ chối',locked:'Bị khóa'};
  const statusClass={pending:'status-pending',approved:'status-approved',denied:'status-denied',locked:'status-locked'};
  const accessLabel={all:'Full',tay:'Bài Tây',tarot:'Tarot',lenormand:'Lenormand',none:'Chưa rõ'};
  const key=sanitizeEmail(u.email);
  let actions='';
  if(u.status==='pending'){
    actions=`
      <button class="act-btn approve" onclick="adminApprove('${key}','${u.email}')">✓ Duyệt</button>
      <button class="act-btn deny" onclick="adminDeny('${key}')">✗ Từ chối</button>`;
  } else if(u.status==='approved'){
    actions=`
      <button class="act-btn lock" onclick="adminLock('${key}')">🔒 Khóa</button>
      <button class="act-btn del" onclick="adminDelete('${key}')">🗑</button>`;
  } else {
    actions=`
      <button class="act-btn approve" onclick="adminApprove('${key}','${u.email}')">↩ Mở</button>
      <button class="act-btn del" onclick="adminDelete('${key}')">🗑</button>`;
  }
  return `<div class="user-row">
    <div class="user-info">
      <div class="user-email">${u.email}</div>
      <div class="user-meta">
        <span class="status-badge ${statusClass[u.status]||'status-pending'}">${statusLabel[u.status]||'?'}</span>
        <span style="margin-left:6px;font-size:11px;color:var(--muted)">Mã: ${u.memberCode||'—'} · Quyền: ${accessLabel[u.access]||'—'}</span>
      </div>
    </div>
    <div class="user-actions" style="flex-wrap:wrap;justify-content:flex-end">
      <button class="act-btn" onclick="adminEditAccess('${key}','${u.email}','${u.access||'all'}')">✏ Quyền</button>
      ${actions}
    </div>
  </div>`;
}

async function adminApprove(key,email){
  // Show access picker
  const access=await promptAccess();
  if(!access)return;
  await db.ref('users/'+key).update({status:'approved',access,approvedAt:Date.now()});
  showToast('✅ Đã phê duyệt: '+email,'success');
}

async function adminDeny(key){
  if(!confirm('Từ chối tài khoản này?'))return;
  await db.ref('users/'+key).update({status:'denied'});
  showToast('Đã từ chối','error');
}

async function adminLock(key){
  await db.ref('users/'+key).update({status:'locked'});
  showToast('Đã khóa tài khoản');
}

async function adminDelete(key){
  if(!confirm('Xóa tài khoản này? Không thể hoàn tác!'))return;
  await db.ref('users/'+key).remove();
  showToast('Đã xóa tài khoản');
}

async function adminEditAccess(key,email,currentAcc){
  openModal(`
    <div class="modal-num">Chỉnh quyền truy cập</div>
    <div class="modal-title" style="font-size:18px">${email}</div>
    <div style="height:1px;background:var(--border);margin:12px 0"></div>
    <div class="access-modal">
      <p style="font-size:12px;color:var(--muted);margin-bottom:10px">Chọn quyền truy cập:</p>
      <select class="admin-select" id="access-picker">
        <option value="all" ${currentAcc==='all'?'selected':''}>🌟 Full Access</option>
        <option value="tay" ${currentAcc==='tay'?'selected':''}>♠ Bài Tây only</option>
        <option value="tarot" ${currentAcc==='tarot'?'selected':''}>🔮 Tarot only</option>
        <option value="lenormand" ${currentAcc==='lenormand'?'selected':''}>🌿 Lenormand only</option>
      </select>
    </div>
    <button class="btn-small" style="width:100%;margin-top:14px" onclick="saveAccess('${key}')">Lưu</button>
  `);
}

async function saveAccess(key){
  const val=document.getElementById('access-picker').value;
  await db.ref('users/'+key).update({access:val});
  closeModal();
  showToast('✅ Đã cập nhật quyền','success');
}

async function adminCreateUser(){
  const email=document.getElementById('new-email').value.trim();
  const pass=document.getElementById('new-pass').value;
  const access=document.getElementById('new-access').value;
  if(!email||!pass){showToast('Vui lòng điền đủ thông tin','error');return;}

  try{
    // Create in Auth
    const cred=await auth.createUserWithEmailAndPassword(email,pass);
    // Save to DB
    await db.ref('users/'+sanitizeEmail(email)).set({
      email,status:'approved',access,memberCode:'admin-created',createdAt:Date.now()
    });
    // Sign back in as admin
