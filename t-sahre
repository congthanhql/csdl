<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>T-SHARE · Tra Cứu Bài</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>

<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>

<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}

[data-theme="dark"]{
  --bg:#080910;--bg2:#0d0e1a;--surface:#111320;--surface2:#171a2e;--surface3:#1e2238;
  --border:#ffffff0d;--border2:#ffffff18;--border3:#ffffff2a;
  --gold:#c9a84c;--gold2:#e8c97a;--gold-glow:rgba(201,168,76,.2);
  --text:#ede9df;--text2:#bfb9a8;--muted:#6e6a5e;
  --accent:#7b6ee8;--red:#e85454;--teal:#4ecdc4;--amber:#f4a836;--green:#52c97a;
  --shadow:0 12px 40px rgba(0,0,0,.6);--shadow2:0 4px 16px rgba(0,0,0,.45);
  --overlay:rgba(0,0,0,.8);--card-hover:#1c2040;
}
[data-theme="light"]{
  --bg:#f2ede4;--bg2:#ede8dd;--surface:#ffffff;--surface2:#f8f4ec;--surface3:#f0ebe0;
  --border:#00000008;--border2:#00000014;--border3:#00000022;
  --gold:#9a6f1e;--gold2:#c49038;--gold-glow:rgba(154,111,30,.15);
  --text:#18150d;--text2:#3a3420;--muted:#8a8070;
  --accent:#4e42c0;--red:#c42020;--teal:#177a76;--amber:#b56a10;--green:#1a7a3c;
  --shadow:0 8px 28px rgba(0,0,0,.1);--shadow2:0 2px 10px rgba(0,0,0,.07);
  --overlay:rgba(0,0,0,.55);--card-hover:#f0ebe0;
}

:root{--sidebar-w:240px;--header-h:64px}

body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s}

[data-theme="dark"] body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 60% 40% at 10% 5%,rgba(123,110,232,.08) 0%,transparent 60%),
    radial-gradient(ellipse 50% 30% at 90% 90%,rgba(201,168,76,.06) 0%,transparent 60%),
    radial-gradient(1.5px 1.5px at 20% 30%,rgba(255,255,255,.12) 0%,transparent 100%),
    radial-gradient(1px 1px at 70% 15%,rgba(255,255,255,.1) 0%,transparent 100%),
    radial-gradient(1px 1px at 50% 70%,rgba(255,255,255,.08) 0%,transparent 100%);
}

/* ── SCREENS ── */
.screen{display:none;min-height:100vh;position:relative;z-index:1}
.screen.active{display:flex;flex-direction:column}

/* ── LOADING ── */
#screen-loading{align-items:center;justify-content:center}
.sigil{font-family:'Cormorant Garamond',serif;color:var(--gold);line-height:1;
  filter:drop-shadow(0 0 18px var(--gold-glow))}
.loader-ring{width:48px;height:48px;border:2px solid var(--border2);
  border-top-color:var(--gold);border-radius:50%;animation:spin .8s linear infinite;margin-top:20px}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── LOGIN ── */
#screen-login{align-items:center;justify-content:center;padding:20px}
.login-wrap{width:100%;max-width:400px}
.login-brand{text-align:center;margin-bottom:32px}
.login-brand .sigil{font-size:56px;display:block;margin-bottom:10px}
.login-brand h1{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:var(--text)}
.login-brand p{font-size:11px;color:var(--muted);letter-spacing:.15em;text-transform:uppercase;margin-top:4px}
.login-card{background:var(--surface);border:1px solid var(--border2);border-radius:20px;
  padding:32px 28px;box-shadow:var(--shadow)}
.field{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
.field label{font-size:11px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;font-weight:500}
.field-input-wrap{position:relative}
.field input{width:100%;background:var(--surface2);border:1.5px solid var(--border2);border-radius:12px;
  padding:13px 16px;color:var(--text);font-size:15px;font-family:'DM Sans',sans-serif;
  outline:none;transition:border .2s,background .2s;-webkit-appearance:none}
.field input:focus{border-color:var(--gold);background:var(--surface3)}
.field input::placeholder{color:var(--muted)}
.err-msg{color:var(--red);font-size:13px;text-align:center;display:none;padding:6px 0 2px;animation:shake .4s}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
.btn-primary{width:100%;background:linear-gradient(135deg,var(--gold),var(--gold2));
  color:#1a1208;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:600;
  font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .2s,transform .1s;margin-top:6px;
  letter-spacing:.02em}
.btn-primary:hover{opacity:.9}
.btn-primary:active{transform:scale(.98)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed}
.theme-fab{position:fixed;top:16px;right:16px;z-index:50;background:var(--surface);
  border:1.5px solid var(--border2);border-radius:50%;width:42px;height:42px;
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;
  transition:all .2s;box-shadow:var(--shadow2)}
.theme-fab:hover{border-color:var(--gold)}

/* ── ERROR ── */
#screen-error{align-items:center;justify-content:center;padding:20px}
.mid-card{width:100%;max-width:380px;background:var(--surface);border:1px solid var(--border2);
  border-radius:20px;padding:36px 28px;box-shadow:var(--shadow);text-align:center}
.mid-card .sigil{font-size:44px;display:block;margin-bottom:12px}
.mid-card h2{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:400;margin-bottom:4px}
.mid-card .sub{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6}
.btn-ghost{width:100%;background:transparent;border:1.5px solid var(--border2);color:var(--muted);
  border-radius:12px;padding:12px;font-size:14px;font-family:'DM Sans',sans-serif;cursor:pointer;
  margin-top:10px;transition:all .2s}
.btn-ghost:hover{border-color:var(--red);color:var(--red)}
.icon-large{font-size:52px;margin-bottom:16px}

/* ══════════════════════════════════
   DESKTOP LAYOUT (≥768px)
══════════════════════════════════ */
@media(min-width:768px){
  #screen-app{flex-direction:row}
  .sidebar{display:flex!important;flex-direction:column;width:var(--sidebar-w);
    background:var(--surface);border-right:1px solid var(--border2);
    padding:24px 0;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
  .sidebar-brand{padding:0 20px 24px;border-bottom:1px solid var(--border);margin-bottom:16px}
  .sidebar-brand .sigil{font-size:32px;display:block;margin-bottom:6px}
  .sidebar-brand h2{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;color:var(--gold)}
  .sidebar-brand p{font-size:10px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase}
  .sidebar-nav{flex:1;padding:0 10px}
  .sidebar-item{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:12px;
    cursor:pointer;transition:all .2s;color:var(--muted);font-size:14px;font-weight:500;
    margin-bottom:4px;border:1.5px solid transparent}
  .sidebar-item:hover{color:var(--text);background:var(--surface2)}
  .sidebar-item.active{color:var(--gold);background:var(--surface2);border-color:var(--border2)}
  .sidebar-item .si-icon{font-size:20px;width:28px;text-align:center;flex-shrink:0}
  .sidebar-footer{padding:16px 20px;border-top:1px solid var(--border);margin-top:auto}
  .sidebar-footer-actions{display:flex;gap:8px}
  .app-content{flex:1;min-width:0;overflow-y:auto}
  .app-header{display:flex!important}
  .bottom-nav{display:none!important}
  .app-header{border-bottom:1px solid var(--border);padding:16px 24px;
    display:flex;align-items:center;justify-content:space-between;
    background:var(--bg);position:sticky;top:0;z-index:100}
  .panel{padding:24px 28px}
  .cards-grid{grid-template-columns:repeat(3,1fr)!important}
}
@media(min-width:1100px){
  .cards-grid{grid-template-columns:repeat(4,1fr)!important}
  :root{--sidebar-w:260px}
}

/* ── APP LAYOUT (mobile base) ── */
#screen-app{padding-bottom:72px}
.sidebar{display:none}
.app-content{flex:1;min-width:0}

.app-header{padding:14px 16px;display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;background:var(--bg);border-bottom:1px solid var(--border)}
.app-header-left{display:flex;align-items:center;gap:10px}
.header-logo-icon{font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--gold)}
.header-title{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--text);font-weight:400}
.header-sub{font-size:10px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
.header-actions{display:flex;gap:8px;align-items:center}
.icon-btn{background:var(--surface);border:1.5px solid var(--border2);border-radius:50%;
  width:38px;height:38px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:16px;color:var(--muted);transition:all .2s;flex-shrink:0}
.icon-btn:hover{border-color:var(--gold);color:var(--gold)}

/* ── BOTTOM NAV (mobile) ── */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;z-index:200;background:var(--surface);
  border-top:1px solid var(--border2);display:flex;padding:6px 4px calc(6px + env(safe-area-inset-bottom));
  box-shadow:0 -6px 24px rgba(0,0,0,.2)}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 2px;
  border-radius:10px;cursor:pointer;transition:all .2s;color:var(--muted);font-size:10px;
  font-weight:500;letter-spacing:.01em;-webkit-user-select:none;user-select:none}
.nav-item:hover{color:var(--text)}
.nav-item.active{color:var(--gold)}
.nav-item.active .nav-icon{background:var(--gold-glow)}
.nav-icon{font-size:20px;width:36px;height:26px;display:flex;align-items:center;
  justify-content:center;border-radius:8px;transition:all .2s}

/* ── PANELS ── */
.panel{display:none;padding:16px 14px;animation:fadeIn .2s ease}
.panel.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── SEARCH ── */
.search-bar{position:relative;margin-bottom:14px}
.search-bar input{width:100%;background:var(--surface);border:1.5px solid var(--border2);
  border-radius:14px;padding:12px 16px 12px 44px;color:var(--text);font-size:15px;
  font-family:'DM Sans',sans-serif;outline:none;transition:border .2s;-webkit-appearance:none}
.search-bar input:focus{border-color:var(--gold)}
.search-bar input::placeholder{color:var(--muted)}
.search-icon{position:absolute;left:15px;top:50%;transform:translateY(-50%);font-size:16px;
  color:var(--muted);pointer-events:none}

/* ── FILTER CHIPS ── */
.chips{display:flex;gap:6px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:4px;
  margin-bottom:14px;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{flex-shrink:0;background:var(--surface);border:1.5px solid var(--border2);
  border-radius:999px;padding:7px 16px;font-size:12px;font-weight:500;color:var(--muted);
  cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;white-space:nowrap}
.chip:active{transform:scale(.95)}
.chip.active{background:var(--surface2);border-color:var(--gold);color:var(--gold)}

/* ── CARDS GRID ── */
.cards-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
@media(min-width:480px){.cards-grid{grid-template-columns:repeat(3,1fr)}}
.card-item{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;
  padding:14px 12px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.card-item::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,
  transparent 60%,rgba(255,255,255,.02));pointer-events:none}
.card-item:hover{background:var(--card-hover);border-color:var(--border2);
  transform:translateY(-2px);box-shadow:var(--shadow2)}
.card-item:active{transform:scale(.97)}
.card-suit{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.card-name{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--text);
  margin-bottom:2px;line-height:1.2;font-weight:400}
.card-name-vi{font-size:12px;color:var(--gold);margin-bottom:5px;font-weight:500}
.card-keys{font-size:11px;color:var(--muted);line-height:1.5;display:-webkit-box;
  -webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-item.wands .card-name-vi{color:#e8634c}
.card-item.cups .card-name-vi{color:#5aaee8}
.card-item.swords .card-name-vi{color:#8fa0b0}
.card-item.pentacles .card-name-vi{color:var(--amber)}
.card-item.major .card-name-vi{color:var(--accent)}

/* ── LENORMAND ── */
.len-grid{display:grid;grid-template-columns:1fr;gap:10px}
@media(min-width:500px){.len-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:900px){.len-grid{grid-template-columns:repeat(3,1fr)}}
.len-card{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:18px}
.len-badge{display:inline-flex;align-items:center;gap:6px;background:var(--surface2);
  border:1px solid var(--border2);border-radius:8px;padding:4px 12px;font-size:11px;
  color:var(--gold);margin-bottom:10px;font-weight:600;letter-spacing:.05em}
.len-name{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--text);
  margin-bottom:2px;font-weight:400}
.len-vn{font-size:12px;color:var(--muted);margin-bottom:12px;font-style:italic}
.len-fields{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.len-field{background:var(--surface2);border-radius:8px;padding:8px 10px}
.len-field strong{display:block;font-size:9px;color:var(--gold);text-transform:uppercase;
  letter-spacing:.1em;margin-bottom:3px;font-weight:600}
.len-field span{font-size:12px;color:var(--text2);line-height:1.4}
.len-field.full{grid-column:1/-1}

/* ── YES/NO ── */
.yn-wrap{max-width:600px}
.yn-header{margin-bottom:20px}
.yn-header h2{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:400;margin-bottom:4px}
.yn-header p{font-size:13px;color:var(--muted)}
.yn-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.yn-card{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:18px 16px}
.yn-nums{font-family:'Cormorant Garamond',serif;font-size:22px;margin-bottom:8px;font-weight:300}
.yn-result{font-size:13px;color:var(--text2);line-height:1.5}
.yn-result strong{color:var(--text);display:block;font-size:14px;margin-bottom:2px}
.yn-yes .yn-nums{color:var(--teal)}.yn-wait .yn-nums{color:var(--amber)}
.yn-chat .yn-nums{color:var(--accent)}.yn-soon .yn-nums{color:var(--gold2)}
.yn-guide{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:18px}
.yn-guide h4{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);
  margin-bottom:12px;font-weight:600}
.yn-guide li{font-size:13px;color:var(--muted);line-height:2.2;padding-left:4px;margin-left:16px}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:var(--overlay);z-index:500;
  display:none;align-items:flex-end;justify-content:center;padding:0;backdrop-filter:blur(4px)}
@media(min-width:640px){.modal-overlay{align-items:center;padding:24px}}
.modal-overlay.open{display:flex;animation:fadeOverlay .2s}
@keyframes fadeOverlay{from{opacity:0}to{opacity:1}}
.modal{background:var(--surface);border:1px solid var(--border2);
  border-radius:24px 24px 0 0;width:100%;max-height:90vh;overflow-y:auto;
  padding:24px 22px 36px;position:relative;animation:slideUp .25s ease;
  box-shadow:var(--shadow)}
@media(min-width:640px){.modal{border-radius:24px;max-width:520px;max-height:88vh}}
@keyframes slideUp{from{transform:translateY(24px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-drag{width:40px;height:4px;background:var(--border3);border-radius:2px;
  margin:0 auto 22px}
@media(min-width:640px){.modal-drag{display:none}}
.modal-close{position:absolute;top:18px;right:18px;background:var(--surface2);
  border:1px solid var(--border2);border-radius:50%;width:34px;height:34px;
  display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);
  font-size:20px;line-height:1;transition:all .2s;font-weight:300}
.modal-close:hover{color:var(--text);border-color:var(--border3)}
.modal-badge{display:inline-block;background:var(--surface2);border:1px solid var(--border2);
  border-radius:6px;padding:4px 12px;font-size:11px;font-weight:600;letter-spacing:.08em;
  text-transform:uppercase;margin-bottom:10px}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:400;
  color:var(--text);margin-bottom:3px;line-height:1.1}
.modal-vi{font-size:15px;color:var(--gold);margin-bottom:8px;font-weight:500}
.modal-keywords{font-size:13px;color:var(--muted);margin-bottom:16px;
  padding-bottom:16px;border-bottom:1px solid var(--border);line-height:1.6;font-style:italic}
.modal-section{margin-bottom:16px}
.modal-section h4{font-size:10px;text-transform:uppercase;letter-spacing:.12em;
  color:var(--gold);margin-bottom:6px;font-weight:600;opacity:.8}
.modal-section p{font-size:14px;color:var(--text2);line-height:1.7}
.modal-divider{height:1px;background:var(--border);margin:16px 0}
.modal-meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px;padding-top:16px;
  border-top:1px solid var(--border)}
.meta-pill{background:var(--surface2);border:1px solid var(--border);border-radius:10px;
  padding:8px 14px;font-size:11px;color:var(--muted)}
.meta-pill span{display:block;font-size:13px;color:var(--text);margin-top:3px;font-weight:500}

/* ── ADMIN SCREEN ── */
#screen-admin{padding-bottom:0}
@media(min-width:768px){
  #screen-admin{flex-direction:row}
  .admin-sidebar{display:flex!important}
  .admin-main{flex:1;overflow-y:auto;max-height:100vh}
}
.admin-sidebar{display:none;flex-direction:column;width:220px;background:var(--surface);
  border-right:1px solid var(--border2);padding:20px 0;height:100vh;position:sticky;top:0;flex-shrink:0}
.admin-sidebar-brand{padding:0 18px 20px;border-bottom:1px solid var(--border)}
.admin-sidebar-brand .sigil{font-size:28px;color:var(--gold)}
.admin-sidebar-brand h2{font-family:'Cormorant Garamond',serif;font-size:16px;color:var(--gold);font-weight:400;margin-top:6px}
.admin-sidebar-brand p{font-size:10px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:2px}
.admin-header{background:var(--surface);border-bottom:1px solid var(--border2);
  padding:16px 20px;display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100}
.admin-header-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--gold);font-weight:400}
.admin-body{padding:20px;max-width:960px}
.admin-section{background:var(--surface);border:1.5px solid var(--border2);
  border-radius:18px;padding:20px;margin-bottom:16px}
.admin-section h3{font-size:11px;text-transform:uppercase;letter-spacing:.12em;
  color:var(--gold);margin-bottom:16px;font-weight:600;display:flex;align-items:center;gap:8px}
.admin-section h3 .badge{background:var(--surface2);border:1px solid var(--border2);
  border-radius:999px;padding:2px 10px;font-size:11px;color:var(--text2)}
.user-row{display:grid;grid-template-columns:1fr auto;gap:12px;align-items:start;
  padding:12px 0;border-bottom:1px solid var(--border)}
.user-row:last-child{border-bottom:none;padding-bottom:0}
.user-email{font-size:14px;color:var(--text);font-weight:500;word-break:break-all}
.user-meta{display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-top:5px}
.status-badge{font-size:10px;padding:3px 9px;border-radius:999px;font-weight:600;white-space:nowrap}
.status-pending{background:rgba(244,168,54,.12);color:var(--amber);border:1px solid rgba(244,168,54,.25)}
.status-approved{background:rgba(82,201,122,.12);color:var(--green);border:1px solid rgba(82,201,122,.25)}
.status-denied{background:rgba(232,84,84,.12);color:var(--red);border:1px solid rgba(232,84,84,.25)}
