// Simple access prompter using a confirm dialog approach
function promptAccess(){
  return new Promise(resolve=>{
    openModal(`
      <div class="modal-num">Phê duyệt tài khoản</div>
      <div class="modal-title" style="font-size:18px">Chọn quyền truy cập</div>
      <div style="height:1px;background:var(--border);margin:12px 0"></div>
      <select class="admin-select" id="prompt-access" style="margin-bottom:14px">
        <option value="all">🌟 Full Access (Tất cả)</option>
        <option value="tay">♠ Bài Tây only</option>
        <option value="tarot">🔮 Tarot only</option>
        <option value="lenormand">🌿 Lenormand only</option>
      </select>
      <button class="btn-small" style="width:100%" onclick="
        const v=document.getElementById('prompt-access').value;
        closeModal();
        window._promptAccessResolve(v);
      ">Xác nhận</button>
    `);
    window._promptAccessResolve=resolve;
  });
}

