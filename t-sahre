<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>T-SHARE · Tra Cứu Bài</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>

<!-- Firebase SDKs -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>

<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}

/* ─── THEME VARIABLES ─── */
[data-theme="dark"]{
  --bg:#0b0c15;
  --bg2:#0f1020;
  --surface:#141728;
  --surface2:#1c2035;
  --surface3:#242840;
  --border:#ffffff10;
  --border2:#ffffff1e;
  --border3:#ffffff30;
  --gold:#c9a84c;
  --gold2:#e8c97a;
  --text:#e8e4d8;
  --text2:#c5bfb0;
  --muted:#7a7568;
  --accent:#7b6ee8;
  --red:#e85454;
  --teal:#4ecdc4;
  --amber:#f4a836;
  --green:#52c97a;
  --shadow:0 8px 32px rgba(0,0,0,.5);
  --shadow2:0 2px 12px rgba(0,0,0,.4);
  --overlay:rgba(0,0,0,.75);
}
[data-theme="light"]{
  --bg:#f5f2eb;
  --bg2:#ede9e0;
  --surface:#ffffff;
  --surface2:#f8f5ef;
  --surface3:#f0ece3;
  --border:#00000010;
  --border2:#0000001a;
  --border3:#00000028;
  --gold:#a07828;
  --gold2:#c49a3a;
  --text:#1a1710;
  --text2:#3a3520;
  --muted:#8a8070;
  --accent:#5548c8;
  --red:#cc2222;
  --teal:#1a9490;
  --amber:#c47818;
  --green:#1a8040;
  --shadow:0 4px 20px rgba(0,0,0,.12);
  --shadow2:0 2px 8px rgba(0,0,0,.08);
  --overlay:rgba(0,0,0,.5);
}

body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s}

/* ─── STARFIELD (dark only) ─── */
[data-theme="dark"] body::before{
  content:'';position:fixed;inset:0;
  background:radial-gradient(1px 1px at 15% 25%,#ffffff18 0%,transparent 100%),
    radial-gradient(1px 1px at 75% 8%,#ffffff14 0%,transparent 100%),
    radial-gradient(1px 1px at 45% 75%,#ffffff12 0%,transparent 100%),
    radial-gradient(1px 1px at 85% 65%,#ffffff16 0%,transparent 100%);
  pointer-events:none;z-index:0
}

/* ─── SCREENS ─── */
.screen{display:none;min-height:100vh;position:relative;z-index:1}
.screen.active{display:flex;flex-direction:column}

/* ─── LOGIN ─── */
#screen-login{align-items:center;justify-content:center;padding:20px}
.login-card{width:100%;max-width:360px;background:var(--surface);border:1px solid var(--border2);border-radius:24px;padding:36px 28px;box-shadow:var(--shadow)}
.sigil{font-family:'Cormorant Garamond',serif;font-size:52px;color:var(--gold);line-height:1;text-align:center;margin-bottom:12px;filter:drop-shadow(0 0 14px color-mix(in srgb,var(--gold) 40%,transparent))}
.login-title{font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--text);text-align:center;margin-bottom:4px}
.login-sub{font-size:11px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;text-align:center;margin-bottom:28px}
.field{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}
.field label{font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}
.field input{background:var(--surface2);border:1.5px solid var(--border2);border-radius:10px;padding:12px 14px;color:var(--text);font-size:15px;font-family:'DM Sans',sans-serif;outline:none;transition:border .2s,background .2s;width:100%}
.field input:focus{border-color:var(--gold);background:var(--surface3)}
.field input::placeholder{color:var(--muted)}
.btn-primary{width:100%;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#1a1208;border:none;border-radius:10px;padding:14px;font-size:15px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .2s,transform .1s;margin-top:4px}
.btn-primary:hover{opacity:.9}
.btn-primary:active{transform:scale(.98)}
.err-msg{color:var(--red);font-size:13px;text-align:center;display:none;padding:8px 0}
.theme-toggle-login{position:absolute;top:16px;right:16px;background:var(--surface);border:1.5px solid var(--border2);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;color:var(--muted);transition:all .2s}
.theme-toggle-login:hover{border-color:var(--gold);color:var(--gold)}

/* ─── MEMBER CODE SCREEN ─── */
#screen-code{align-items:center;justify-content:center;padding:20px}
.code-card{width:100%;max-width:360px;background:var(--surface);border:1px solid var(--border2);border-radius:24px;padding:36px 28px;box-shadow:var(--shadow);text-align:center}
.code-card .sigil{font-size:40px;margin-bottom:10px}
.code-welcome{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--text);margin-bottom:4px}
.code-user{font-size:13px;color:var(--gold);margin-bottom:24px}
.code-input{background:var(--surface2);border:1.5px solid var(--border2);border-radius:10px;padding:14px;color:var(--text);font-size:16px;font-family:'DM Sans',sans-serif;outline:none;transition:border .2s;width:100%;text-align:center;letter-spacing:.12em;margin-bottom:14px}
.code-input:focus{border-color:var(--gold)}
.btn-logout{background:transparent;border:1.5px solid var(--border2);color:var(--muted);border-radius:8px;padding:8px 18px;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;margin-top:12px;transition:all .2s;width:100%}
.btn-logout:hover{border-color:var(--red);color:var(--red)}

/* ─── PENDING APPROVAL ─── */
#screen-pending{align-items:center;justify-content:center;padding:20px;text-align:center}
.pending-card{width:100%;max-width:360px;background:var(--surface);border:1px solid var(--border2);border-radius:24px;padding:36px 28px;box-shadow:var(--shadow)}
.pending-icon{font-size:48px;margin-bottom:16px}
.pending-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--amber);margin-bottom:8px}
.pending-desc{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:20px}
#screen-error .error-card{text-align:center}
.error-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--red);margin-bottom:8px}

/* ─── MAIN APP ─── */
#screen-app{padding-bottom:80px}
.app-header{padding:16px 16px 0;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;background:var(--bg);border-bottom:1px solid var(--border);padding-bottom:12px}
.app-header-left{display:flex;align-items:center;gap:10px}
.app-logo{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--gold)}
.app-logo span{font-size:11px;color:var(--muted);display:block;letter-spacing:.1em;font-family:'DM Sans',sans-serif;line-height:1}
.header-actions{display:flex;gap:8px;align-items:center}
.icon-btn{background:var(--surface);border:1.5px solid var(--border2);border-radius:50%;width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--muted);transition:all .2s}
.icon-btn:hover{border-color:var(--gold);color:var(--gold)}

/* ─── BOTTOM NAV ─── */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;z-index:200;background:var(--surface);border-top:1px solid var(--border2);display:flex;padding:8px 4px calc(8px + env(safe-area-inset-bottom));box-shadow:0 -4px 20px rgba(0,0,0,.2)}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;padding:6px 4px;border-radius:12px;cursor:pointer;transition:all .2s;color:var(--muted);font-size:10px;font-weight:500;letter-spacing:.02em;-webkit-user-select:none;user-select:none}
.nav-item:hover{color:var(--text)}
.nav-item.active{color:var(--gold)}
.nav-item.active .nav-icon{background:color-mix(in srgb,var(--gold) 15%,transparent)}
.nav-icon{font-size:20px;width:36px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:8px;transition:all .2s}

/* ─── PANELS ─── */
.panel{display:none;padding:16px 14px;animation:fadeIn .2s ease}
.panel.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ─── SEARCH ─── */
.search-bar{position:relative;margin-bottom:14px}
.search-bar input{width:100%;background:var(--surface);border:1.5px solid var(--border2);border-radius:14px;padding:12px 16px 12px 42px;color:var(--text);font-size:15px;font-family:'DM Sans',sans-serif;outline:none;transition:border .2s;-webkit-appearance:none}
.search-bar input:focus{border-color:var(--gold)}
.search-bar input::placeholder{color:var(--muted)}
.search-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:16px;color:var(--muted);pointer-events:none}

/* ─── SUIT FILTER CHIPS ─── */
.chips{display:flex;gap:6px;flex-wrap:nowrap;overflow-x:auto;padding-bottom:4px;margin-bottom:14px;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{flex-shrink:0;background:var(--surface);border:1.5px solid var(--border2);border-radius:999px;padding:6px 14px;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s;white-space:nowrap}
.chip:active{transform:scale(.95)}
.chip.active{background:var(--surface2);border-color:var(--gold);color:var(--gold)}

/* ─── CARD GRID ─── */
.cards-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
@media(min-width:480px){.cards-grid{grid-template-columns:repeat(3,1fr)}}
@media(min-width:768px){.cards-grid{grid-template-columns:repeat(4,1fr)}}
.card-item{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:14px 12px;cursor:pointer;transition:all .2s;active-scale:.97}
.card-item:active{transform:scale(.97);background:var(--surface2)}
.card-suit{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.card-name{font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--text);margin-bottom:2px;line-height:1.2}
.card-name-vi{font-size:12px;color:var(--gold);margin-bottom:4px}
.card-keys{font-size:11px;color:var(--muted);line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-item.wands .card-name-vi{color:#e8634c}
.card-item.cups .card-name-vi{color:#4e9de8}
.card-item.swords .card-name-vi{color:#8fa0b0}
.card-item.pentacles .card-name-vi{color:var(--amber)}
.card-item.major .card-name-vi{color:var(--accent)}

/* ─── LENORMAND GRID ─── */
.len-grid{display:grid;grid-template-columns:1fr;gap:10px}
@media(min-width:480px){.len-grid{grid-template-columns:repeat(2,1fr)}}
.len-card{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:16px}
.len-badge{display:inline-block;background:var(--surface2);border:1px solid var(--border2);border-radius:6px;padding:3px 10px;font-size:11px;color:var(--gold);margin-bottom:8px}
.len-name{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--text);margin-bottom:2px}
.len-vn{font-size:12px;color:var(--gold);margin-bottom:8px}
.len-field{font-size:12px;line-height:1.5;margin-bottom:4px;color:var(--text2)}
.len-field strong{color:var(--muted);margin-right:5px;font-size:11px;text-transform:uppercase;letter-spacing:.05em}

/* ─── YES/NO ─── */
.yn-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.yn-card{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:18px 14px}
.yn-nums{font-family:'Cormorant Garamond',serif;font-size:26px;margin-bottom:6px}
.yn-result{font-size:13px;color:var(--text2);line-height:1.4}
.yn-result strong{color:var(--text)}
.yn-yes .yn-nums{color:var(--teal)}
.yn-wait .yn-nums{color:var(--amber)}
.yn-chat .yn-nums{color:var(--accent)}
.yn-soon .yn-nums{color:var(--gold2)}
.yn-guide{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:16px}
.yn-guide h4{font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);margin-bottom:10px}
.yn-guide li{font-size:13px;color:var(--muted);line-height:2;padding-left:4px;margin-left:14px}

/* ─── MODAL ─── */
.modal-overlay{position:fixed;inset:0;background:var(--overlay);z-index:500;display:none;align-items:flex-end;justify-content:center;padding:0}
@media(min-width:600px){.modal-overlay{align-items:center;padding:20px}}
.modal-overlay.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:24px 24px 0 0;width:100%;max-height:88vh;overflow-y:auto;padding:24px 20px 32px;position:relative;animation:slideUp .25s ease}
@media(min-width:600px){.modal{border-radius:24px;max-width:480px;max-height:90vh}}
@keyframes slideUp{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-handle{width:40px;height:4px;background:var(--border3);border-radius:2px;margin:0 auto 20px}
@media(min-width:600px){.modal-handle{display:none}}
.modal-close{position:absolute;top:16px;right:16px;background:var(--surface2);border:1px solid var(--border);border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);font-size:20px;line-height:1;transition:all .2s}
.modal-close:hover{color:var(--text);border-color:var(--border3)}
.modal-num{font-size:11px;color:var(--muted);letter-spacing:.1em;margin-bottom:6px}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--text);margin-bottom:3px}
.modal-vi{font-size:14px;color:var(--gold);margin-bottom:8px}
.modal-keys{font-size:13px;color:var(--muted);margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.modal-section{margin-bottom:14px}
.modal-section h4{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);margin-bottom:5px}
.modal-section p{font-size:14px;color:var(--text2);line-height:1.65}
.modal-meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px;padding-top:16px;border-top:1px solid var(--border)}
.meta-pill{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:6px 12px;font-size:11px;color:var(--muted)}
.meta-pill span{display:block;font-size:12px;color:var(--text);margin-top:2px}

/* ─── ADMIN ─── */
#screen-admin{padding-bottom:20px}
.admin-header{background:var(--surface);border-bottom:1px solid var(--border2);padding:16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.admin-title{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--gold)}
.admin-body{padding:16px;max-width:900px;margin:0 auto}
.admin-section{background:var(--surface);border:1.5px solid var(--border2);border-radius:16px;padding:18px;margin-bottom:16px}
.admin-section h3{font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);margin-bottom:14px}
.user-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.user-row:last-child{border-bottom:none}
.user-info{flex:1;min-width:0}
.user-email{font-size:13px;color:var(--text);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.user-meta{font-size:11px;color:var(--muted);margin-top:2px}
.status-badge{font-size:10px;padding:3px 8px;border-radius:999px;font-weight:600;white-space:nowrap;flex-shrink:0}
.status-pending{background:color-mix(in srgb,var(--amber) 15%,transparent);color:var(--amber);border:1px solid color-mix(in srgb,var(--amber) 30%,transparent)}
.status-approved{background:color-mix(in srgb,var(--green) 15%,transparent);color:var(--green);border:1px solid color-mix(in srgb,var(--green) 30%,transparent)}
.status-denied{background:color-mix(in srgb,var(--red) 15%,transparent);color:var(--red);border:1px solid color-mix(in srgb,var(--red) 30%,transparent)}
.status-locked{background:color-mix(in srgb,var(--muted) 15%,transparent);color:var(--muted);border:1px solid color-mix(in srgb,var(--muted) 30%,transparent)}
.user-actions{display:flex;gap:6px;flex-shrink:0}
.act-btn{border:1.5px solid var(--border2);border-radius:7px;padding:5px 10px;font-size:11px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;background:var(--surface2);color:var(--muted)}
.act-btn.approve{border-color:color-mix(in srgb,var(--green) 40%,transparent);color:var(--green)}
.act-btn.deny{border-color:color-mix(in srgb,var(--red) 40%,transparent);color:var(--red)}
.act-btn.lock{border-color:color-mix(in srgb,var(--amber) 40%,transparent);color:var(--amber)}
.act-btn.del{border-color:color-mix(in srgb,var(--red) 40%,transparent);color:var(--red)}
.act-btn:hover{opacity:.8}
.admin-form{display:flex;flex-direction:column;gap:10px}
.admin-input{background:var(--surface2);border:1.5px solid var(--border2);border-radius:10px;padding:11px 14px;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;width:100%;transition:border .2s}
.admin-input:focus{border-color:var(--gold)}
.admin-select{background:var(--surface2);border:1.5px solid var(--border2);border-radius:10px;padding:11px 14px;color:var(--text);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;width:100%;transition:border .2s;cursor:pointer}
.btn-small{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#1a1208;border:none;border-radius:8px;padding:10px 18px;font-size:13px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .2s}
.btn-small:hover{opacity:.88}
.access-modal{background:var(--surface2);border-radius:12px;padding:14px;margin-top:10px}
.access-modal label{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text2);padding:5px 0;cursor:pointer}
.access-modal input[type=checkbox]{width:16px;height:16px;accent-color:var(--gold)}

/* ─── TOAST ─── */
.toast{position:fixed;bottom:calc(80px + env(safe-area-inset-bottom) + 12px);left:50%;transform:translateX(-50%) translateY(20px);background:var(--surface3);border:1px solid var(--border2);border-radius:12px;padding:10px 20px;font-size:13px;color:var(--text);box-shadow:var(--shadow);opacity:0;transition:all .3s;z-index:800;white-space:nowrap;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.toast.success{border-color:color-mix(in srgb,var(--green) 50%,transparent);color:var(--green)}
.toast.error{border-color:color-mix(in srgb,var(--red) 50%,transparent);color:var(--red)}

/* ─── EMPTY STATE ─── */
.empty{text-align:center;padding:40px 20px;color:var(--muted)}
.empty-icon{font-size:40px;margin-bottom:10px}
.empty p{font-size:13px}

/* ─── LOADING ─── */
.spinner{display:inline-block;width:20px;height:20px;border:2px solid var(--border2);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;gap:16px}
.loading-screen .sigil{font-size:48px}

/* ─── ACCESS DENIED ─── */
.locked-panel{display:flex;align-items:center;justify-content:center;min-height:200px;flex-direction:column;gap:12px;color:var(--muted);text-align:center;padding:20px}
.locked-panel .lock-icon{font-size:36px}
.locked-panel p{font-size:14px;line-height:1.6}
</style>
</head>
<body>

<!-- ══════ LOADING ══════ -->
<div id="screen-loading" class="screen active">
  <div class="loading-screen">
    <div class="sigil">✦</div>
    <div class="spinner"></div>
  </div>
</div>

<!-- ══════ LOGIN ══════ -->
<div id="screen-login" class="screen">
  <button class="theme-toggle-login" onclick="toggleTheme()" style="position:fixed;top:16px;right:16px;z-index:10">🌙</button>
  <div class="login-card">
    <div class="sigil">✦</div>
    <div class="login-title">Hệ Thống Tra Cứu Bài</div>
    <div class="login-sub">T-SHARE · Bioverify</div>
    <div class="field">
      <label>Email</label>
      <input type="email" id="l-user" placeholder="email@example.com" autocomplete="email"/>
    </div>
    <div class="field">
      <label>Mật khẩu</label>
      <input type="password" id="l-pass" placeholder="••••••••" autocomplete="current-password"/>
    </div>
    <div class="err-msg" id="l-err">⚠ Sai tài khoản hoặc mật khẩu</div>
