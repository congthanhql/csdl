function renderLen(){
  const q=document.getElementById('len-search').value.toLowerCase();
  const grid=document.getElementById('len-grid');
  const filtered=lenData.filter(c=>
    c.name.toLowerCase().includes(q)||c.vn.toLowerCase().includes(q)||String(c.number).includes(q)
  );
  grid.innerHTML=filtered.length?filtered.map(c=>`
    <div class="len-card">
      <div class="len-badge">#${c.number} — ${c.name}</div>
      <div class="len-name">${c.vn}</div>
      <div class="len-vn">${c.keywords}</div>
      <div class="len-field"><strong>Tổng quan</strong>${c.overview}</div>
      <div class="len-field"><strong>Sự nghiệp</strong>${c.career}</div>
      <div class="len-field"><strong>Tình cảm</strong>${c.love}</div>
      <div class="len-field"><strong>Sức khỏe</strong>${c.health}</div>
      <div class="len-field"><strong>Thời gian</strong>${c.timing}</div>
    </div>`).join(''):'<div class="empty"><p>Không tìm thấy</p></div>';
}

document.getElementById('len-search').addEventListener('input',renderLen);

