function renderLen(){
  const q=document.getElementById('len-search').value.toLowerCase();
  const grid=document.getElementById('len-grid');
  const filtered=lenData.filter(c=>c.name.toLowerCase().includes(q)||c.vn.toLowerCase().includes(q)||String(c.number).includes(q));
  grid.innerHTML=filtered.length?filtered.map(c=>`
    <div class="len-card">
      <div class="len-badge">#${c.number} — ${c.name}</div>
      <div class="len-name">${c.vn}</div>
      <div class="len-vn">${c.keywords}</div>
      <div class="len-fields">
        <div class="len-field full"><strong>Tổng quan</strong><span>${c.overview}</span></div>
        <div class="len-field"><strong>Sự nghiệp</strong><span>${c.career}</span></div>
        <div class="len-field"><strong>Tình cảm</strong><span>${c.love}</span></div>
        <div class="len-field"><strong>Sức khỏe</strong><span>${c.health}</span></div>
        <div class="len-field"><strong>Thời gian</strong><span>${c.timing}</span></div>
      </div>
    </div>`).join(''):'<div class="empty"><p>Không tìm thấy lá bài nào</p></div>';
}
document.getElementById('len-search').addEventListener('input',renderLen);

