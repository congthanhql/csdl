  <!-- PAGE: ADMIN -->
  <div id="page-admin" class="page">
    <div id="admin-login-view">
      <div class="login-card">
        <div class="login-icon">🔐</div>
        <div class="login-title">Khu Vực Admin</div>
        <div class="login-sub">Đăng nhập để quản lý đặt lịch</div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" class="form-input" id="admin-email" placeholder="admin@example.com" value="bioverify@googlegroups.com">
        </div>
        <div class="form-group">
          <label class="form-label">Mật Khẩu</label>
          <input type="password" class="form-input" id="admin-pass" placeholder="••••••••" value="Thanh123@">
        </div>
        <button class="login-btn" onclick="adminLogin()">🔓 Đăng Nhập</button>
      </div>
    </div>

    <div id="admin-dashboard-view" style="display:none">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
        <div class="section-title" style="margin-top:0">📊 Tổng Quan</div>
        <button onclick="adminLogout()" style="background:none;border:1px solid var(--border);color:var(--text3);padding:6px 11px;border-radius:20px;font-size:12px;cursor:pointer;font-family:'Be Vietnam Pro',sans-serif;">Đăng xuất</button>
      </div>

      <div class="stats-grid">
        <div class="stat-card total"><div class="stat-number" id="stat-total">0</div><div class="stat-label">📋 Tổng Khách</div></div>
        <div class="stat-card pending"><div class="stat-number" id="stat-pending">0</div><div class="stat-label">⏳ Chờ Xử Lý</div></div>
        <div class="stat-card confirmed"><div class="stat-number" id="stat-confirmed">0</div><div class="stat-label">✅ Xác Nhận</div></div>
        <div class="stat-card rejected"><div class="stat-number" id="stat-rejected">0</div><div class="stat-label">❌ Từ Chối</div></div>
      </div>

      <div class="search-bar">
        <span>🔍</span>
        <input type="text" placeholder="Tìm theo tên, SĐT, Gmail..." id="search-input" oninput="filterBookings()">
      </div>

      <div class="filter-bar">
        <div class="filter-chip active" onclick="setFilter('all', this)">Tất Cả</div>
        <div class="filter-chip" onclick="setFilter('pending', this)">⏳ Chờ</div>
        <div class="filter-chip" onclick="setFilter('confirmed', this)">✅ Xác Nhận</div>
        <div class="filter-chip" onclick="setFilter('rejected', this)">❌ Từ Chối</div>
      </div>

      <div id="bookings-list">
        <div class="loading-state"><div class="spinner"></div><div style="margin-top:10px;color:var(--text3);font-size:13px;">Đang tải...</div></div>
      </div>
    </div>
  </div>
</div>

<!-- BOTTOM NAV -->
<div class="bottom-nav">
  <button class="nav-item active" id="nav-booking" onclick="switchPage('booking')">
    <div class="nav-icon">🔮</div>
    <div class="nav-label">Đặt Lịch</div>
  </button>
  <button class="nav-item" id="nav-admin" onclick="switchPage('admin')">
    <div class="nav-icon">⚙️</div>
    <div class="nav-label">Quản Lý</div>
  </button>
</div>

<!-- DETAIL MODAL -->
<div class="modal-overlay" id="detail-modal">
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-title" id="modal-title">Chi Tiết Đặt Lịch</div>
    <div id="modal-content"></div>
    <div class="action-row" id="modal-actions"></div>
    <button onclick="closeModal()" style="width:100%;padding:11px;background:none;border:1px solid var(--border);color:var(--text3);border-radius:var(--radius-sm);font-size:13px;cursor:pointer;margin-top:8px;font-family:'Be Vietnam Pro',sans-serif;">Đóng</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.6.0/jspdf.plugin.autotable.min.js"></script>

<script>
// THEME - default theo thiết bị
const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
let isDark = localStorage.getItem('theme') ? localStorage.getItem('theme') === 'dark' : prefersDark;
function applyTheme() {
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  document.getElementById('theme-btn').textContent = isDark ? '☀️' : '🌙';
}
function toggleTheme() {
  isDark = !isDark;
  localStorage.setItem('theme', isDark ? 'dark' : 'light');
  applyTheme();
}
applyTheme();

// FIREBASE
const firebaseConfig = {
  apiKey: "AIzaSyDtAU-Iqn-u39_mgkxRZ3fIF_Kyxqn-Gyg",
  authDomain: "csdl-bio.firebaseapp.com",
  databaseURL: "https://csdl-bio-default-rtdb.firebaseio.com",
  projectId: "csdl-bio",
  storageBucket: "csdl-bio.firebasestorage.app",
  messagingSenderId: "568258817515",
  appId: "1:568258817515:web:595a8afe906a3143a63dae"
};
firebase.initializeApp(firebaseConfig);
const db = firebase.database();

// STATE
let selectedDeck = 'Bài Tây';
let selectedPackage = 'Hiện Tại';
let selectedCategory = 'general';
let isAdmin = false;
let allBookings = [];
let currentFilter = 'all';
let userQuestions = [];

// THEME listener
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
  if (!localStorage.getItem('theme')) { isDark = e.matches; applyTheme(); }
});

// PAGE NAV
function switchPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.getElementById('nav-' + page).classList.add('active');
  if (page === 'admin' && isAdmin) loadBookings();
}
function showAdminLogin() { switchPage('admin'); }

// CATEGORY
function selectCategory(cat, el) {
  selectedCategory = cat;
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('person-section').classList.toggle('open', cat === 'love');
}

// DECK / PACKAGE
function selectDeck(deck, el) {
  selectedDeck = deck;
  document.querySelectorAll('#deck-options .option-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}
function selectPackage(pkg, el) {
  selectedPackage = pkg;
  el.closest('div').querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
}

// QUESTIONS
function renderQuestions() {
  const list = document.getElementById('question-list');
  if (!userQuestions.length) { list.innerHTML = ''; return; }
  list.innerHTML = userQuestions.map((q, i) => `
    <div class="question-item">
      <div class="question-num">${i+1}</div>
      <div class="question-text">${escHtml(q)}</div>
      <button class="question-del" onclick="removeQuestion(${i})" title="Xóa câu hỏi">×</button>
    </div>
  `).join('');
}
function addQuestion() {
  const inp = document.getElementById('new-question-input');
  const val = inp.value.trim();
  if (!val) { showToast('⚠ Nhập câu hỏi trước!', 'error'); return; }
  if (userQuestions.length >= 5) { showToast('⚠ Tối đa 5 câu hỏi!', 'error'); return; }
  userQuestions.push(val);
  inp.value = '';
  renderQuestions();
}
function removeQuestion(idx) {
  userQuestions.splice(idx, 1);
  renderQuestions();
}
function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// SUBMIT
async function submitBooking() {
  const name = document.getElementById('f-name').value.trim();
  const dob = document.getElementById('f-dob').value;
  const phone = document.getElementById('f-phone').value.trim();
  const email = document.getElementById('f-email').value.trim();
  const gender = document.getElementById('f-gender').value;

  if (!name) { showToast('⚠ Vui lòng nhập họ tên!', 'error'); return; }
  if (!dob) { showToast('⚠ Vui lòng chọn ngày sinh!', 'error'); return; }
  if (!phone) { showToast('⚠ Vui lòng nhập số điện thoại!', 'error'); return; }
  if (!email) { showToast('⚠ Vui lòng nhập Gmail!', 'error'); return; }

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<span style="display:inline-block;width:14px;height:14px;border:2px solid rgba(0,0,0,0.2);border-top-color:#333;border-radius:50%;animation:spin 0.8s linear infinite;vertical-align:middle;margin-right:8px"></span>Đang xử lý...';

  const booking = {
    name, dob, phone, email, gender,
    category: selectedCategory,
    deck: selectedDeck,
    package: selectedPackage,
    questions: userQuestions.length ? userQuestions : [],
    status: 'pending',
    seen: false,
    paid: false,
    createdAt: Date.now(),
    createdAtStr: new Date().toLocaleString('vi-VN')
  };

  if (selectedCategory === 'love') {
    booking.partnerName = document.getElementById('f-partner-name').value.trim();
    booking.partnerDob = document.getElementById('f-partner-dob').value;
    booking.partnerGender = document.getElementById('f-partner-gender').value;
    booking.relationship = document.getElementById('f-relationship').value;
  }

  try {
    await db.ref('bookings').push(booking);
    showToast('✅ Đặt lịch thành công!', 'success');
    resetForm();
  } catch(e) {
    console.error(e);
    showToast('❌ Lỗi kết nối, thử lại!', 'error');
  }
  btn.disabled = false;
  btn.innerHTML = '🔮 Xác Nhận Đặt Lịch';
}

function resetForm() {
  ['f-name','f-dob','f-phone','f-email','f-partner-name','f-partner-dob'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  ['f-gender','f-partner-gender'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  userQuestions = [];
  renderQuestions();
  document.getElementById('new-question-input').value = '';
}

// ADMIN
function adminLogin() {
  const e = document.getElementById('admin-email').value.trim();
  const p = document.getElementById('admin-pass').value.trim();
  if (e === 'bioverify@googlegroups.com' && p === 'Thanh123@') {
    isAdmin = true;
    document.getElementById('admin-login-view').style.display = 'none';
    document.getElementById('admin-dashboard-view').style.display = 'block';
    loadBookings();
    showToast('✅ Đăng nhập thành công!', 'success');
  } else {
    showToast('❌ Sai thông tin đăng nhập!', 'error');
  }
}
function adminLogout() {
  isAdmin = false;
  document.getElementById('admin-login-view').style.display = 'block';
  document.getElementById('admin-dashboard-view').style.display = 'none';
}

function loadBookings() {
  db.ref('bookings').orderByChild('createdAt').on('value', snap => {
    allBookings = [];
    snap.forEach(child => allBookings.unshift({ id: child.key, ...child.val() }));
    updateStats();
    renderBookings();
  });
}

function updateStats() {
  document.getElementById('stat-total').textContent = allBookings.length;
  document.getElementById('stat-pending').textContent = allBookings.filter(b=>b.status==='pending').length;
  document.getElementById('stat-confirmed').textContent = allBookings.filter(b=>b.status==='confirmed').length;
  document.getElementById('stat-rejected').textContent = allBookings.filter(b=>b.status==='rejected').length;
}

function setFilter(f, el) {
  currentFilter = f;
  document.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  renderBookings();
}
function filterBookings() { renderBookings(); }

function renderBookings() {
  const search = (document.getElementById('search-input').value || '').toLowerCase();
  const filtered = allBookings.filter(b => {
    const matchF = currentFilter === 'all' || b.status === currentFilter;
    const matchS = !search || b.name.toLowerCase().includes(search) || (b.phone||'').includes(search) || (b.email||'').toLowerCase().includes(search);
    return matchF && matchS;
  });

  const c = document.getElementById('bookings-list');
  if (!filtered.length) {
    c.innerHTML = '<div class="empty-state"><div class="empty-icon">📭</div><div class="empty-text">Không có đặt lịch nào</div></div>';
    return;
  }
  const catLabel = { general:'Tổng Quát', love:'Tình Yêu / GĐ', career:'Sự Nghiệp' };
  c.innerHTML = filtered.map(b => `
    <div class="booking-card" onclick="openDetail('${b.id}')">
      <div class="booking-header">
        <div>
          <div class="booking-name">${escHtml(b.name)}</div>
          <div class="booking-time">📅 ${b.createdAtStr || '--'} · ${b.phone||'--'}</div>
        </div>
        <div class="status-badge ${b.status}">${b.status==='pending'?'⏳ Chờ':b.status==='confirmed'?'✅ Xác nhận':'❌ Từ chối'}</div>
      </div>
      <div class="booking-tags">
        <span class="booking-tag">🃏 ${b.deck}</span>
        <span class="booking-tag">⏳ ${b.package}</span>
        <span class="booking-tag">🎯 ${catLabel[b.category]||b.category}</span>
        ${b.questions&&b.questions.length?`<span class="booking-tag">❓ ${b.questions.length} câu hỏi</span>`:''}
        ${b.seen?'<span class="booking-tag" style="color:var(--accent)">👁 Đã Xem</span>':''}
        ${b.paid?'<span class="booking-tag" style="color:var(--success)">💰 Đã TT</span>':''}
      </div>
    </div>
  `).join('');
}

function openDetail(id) {
  const b = allBookings.find(x=>x.id===id);
  if (!b) return;
  const catLabel = { general:'🌟 Tổng Quát', love:'💕 Tình Yêu / GĐ', career:'💼 Sự Nghiệp' };
  document.getElementById('modal-title').textContent = '📋 ' + b.name;

  let rows = [
    ['Họ Tên', b.name],
    ['Ngày Sinh', b.dob ? new Date(b.dob+'T00:00:00').toLocaleDateString('vi-VN') : '--'],
    ['Giới Tính', b.gender||'--'],
    ['Điện Thoại', b.phone||'--'],
    ['Gmail', b.email||'--'],
    ['Danh Mục', catLabel[b.category]||b.category],
    ['Loại Bài', '🃏 '+b.deck],
    ['Gói Xem', b.package],
    ['Ngày Đặt', b.createdAtStr||'--'],
    ['Trạng Thái', b.status==='pending'?'⏳ Chờ':b.status==='confirmed'?'✅ Xác nhận':'❌ Từ chối'],
    ['Đã Xem', b.seen?'✅ Rồi':'❌ Chưa'],
    ['Thanh Toán', b.paid?'✅ Rồi':'❌ Chưa'],
  ];

  if (b.category==='love' && b.partnerName) {
    rows.splice(5,0,
      ['Tên Người Ấy', b.partnerName||'--'],
      ['Sinh Người Ấy', b.partnerDob?new Date(b.partnerDob+'T00:00:00').toLocaleDateString('vi-VN'):'--'],
      ['Giới Tính (NA)', b.partnerGender||'--'],
      ['Mối Quan Hệ', b.relationship||'--'],
    );
  }

  let questionsHtml = '';
  if (b.questions && b.questions.length) {
    questionsHtml = `<div style="margin-top:12px;padding:12px;background:var(--chip-bg);border-radius:var(--radius-sm);border:1px solid var(--border)">
      <div style="font-size:12px;font-weight:600;color:var(--gold);margin-bottom:10px">❓ Câu Hỏi (${b.questions.length})</div>
      ${b.questions.map((q,i)=>`<div style="font-size:13px;padding:6px 0;border-bottom:1px solid var(--border);color:var(--text)"><span style="color:var(--gold);font-weight:700">${i+1}.</span> ${escHtml(q)}</div>`).join('')}
    </div>`;
  }

  document.getElementById('modal-content').innerHTML =
    rows.map(([k,v]) => `<div class="detail-row"><span class="detail-label">${k}</span><span class="detail-value">${escHtml(String(v))}</span></div>`).join('') + questionsHtml;

  document.getElementById('modal-actions').innerHTML = `
    <button class="action-btn confirm" onclick="updateStatus('${id}','confirmed')">✅ Xác Nhận</button>
    <button class="action-btn reject" onclick="updateStatus('${id}','rejected')">❌ Từ Chối</button>
    <button class="action-btn seen" onclick="markSeen('${id}')">👁 Đã Xem</button>
    <button class="action-btn paid-btn" onclick="markPaid('${id}')">💰 Đã Thanh Toán</button>
    <button class="action-btn pdf" onclick="exportPDF('${id}')">📄 Tải PDF</button>
  `;

  document.getElementById('detail-modal').classList.add('open');
}

function closeModal() { document.getElementById('detail-modal').classList.remove('open'); }

async function updateStatus(id, status) {
  await db.ref('bookings/'+id).update({ status });
  showToast(status==='confirmed'?'✅ Đã xác nhận!':'❌ Đã từ chối!', 'success');
  closeModal();
}
async function markSeen(id) {
  await db.ref('bookings/'+id).update({ seen: true });
  showToast('👁 Đã đánh dấu đã xem!', 'success');
  closeModal();
}
async function markPaid(id) {
  await db.ref('bookings/'+id).update({ paid: true });
  showToast('💰 Đã đánh dấu thanh toán!', 'success');
  closeModal();
}

// EXPORT PDF
function exportPDF(id) {
  const b = allBookings.find(x=>x.id===id);
  if (!b) return;
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation:'portrait', unit:'mm', format:'a4' });
  doc.setFont('helvetica');

  doc.setFillColor(26,18,40);
  doc.rect(0,0,210,38,'F');
  doc.setTextColor(201,168,76);
  doc.setFontSize(18);
  doc.text('DAT LICH XEM BAI - CT-EDU', 105, 16, { align:'center' });
  doc.setFontSize(10);
  doc.setTextColor(180,160,120);
  doc.text('Thong tin chi tiet dat lich', 105, 26, { align:'center' });

  const catLabel = { general:'Tong Quat', love:'Tinh Yeu / Gia Dinh', career:'Su Nghiep' };
  const rows = [
    ['Ho Ten', b.name||'--'],
    ['Ngay Thang Nam Sinh', b.dob?new Date(b.dob+'T00:00:00').toLocaleDateString('vi-VN'):'--'],
    ['Gioi Tinh', b.gender||'--'],
    ['So Dien Thoai', b.phone||'--'],
    ['Gmail', b.email||'--'],
    ['Danh Muc Xem', catLabel[b.category]||b.category],
    ['Loai Bai', b.deck],
    ['Goi Xem', b.package],
    ['Thoi Gian Dat Lich', b.createdAtStr||'--'],
    ['Trang Thai', b.status==='pending'?'Cho xu ly':b.status==='confirmed'?'Da xac nhan':'Tu choi'],
    ['Da Xem', b.seen?'Co':'Chua'],
    ['Da Thanh Toan', b.paid?'Co':'Chua'],
  ];

  if (b.category==='love') {
    rows.splice(5,0,
      ['Nguoi Ay - Ho Ten', b.partnerName||'--'],
      ['Nguoi Ay - Ngay Sinh', b.partnerDob?new Date(b.partnerDob+'T00:00:00').toLocaleDateString('vi-VN'):'--'],
      ['Nguoi Ay - Gioi Tinh', b.partnerGender||'--'],
      ['Moi Quan He', b.relationship||'--'],
    );
  }

  if (b.questions && b.questions.length) {
    b.questions.forEach((q,i) => rows.push(['Cau hoi '+(i+1), q]));
  }

  doc.autoTable({
    startY: 44,
    head: [['Thong Tin', 'Chi Tiet']],
    body: rows,
    theme: 'grid',
    headStyles: { fillColor:[26,18,40], textColor:[201,168,76], fontStyle:'bold', fontSize:11 },
    bodyStyles: { fontSize:10, textColor:[40,30,60] },
    alternateRowStyles: { fillColor:[245,240,255] },
    columnStyles: { 0:{ cellWidth:62, fontStyle:'bold', textColor:[80,60,100] }, 1:{ cellWidth:118 } },
    margin: { left:15, right:15 }
  });

  const finalY = doc.lastAutoTable.finalY + 10;
  doc.setFontSize(9); doc.setTextColor(150,130,100);
  doc.text('Xuat ban: '+new Date().toLocaleString('vi-VN'), 105, finalY, { align:'center' });
  doc.text('CT-EDU | He thong quan ly dat lich xem bai', 105, finalY+6, { align:'center' });
  doc.save('DatLich_'+b.name.replace(/\s/g,'_')+'.pdf');
  showToast('📄 Đã xuất PDF!', 'success');
}

// TOAST
function showToast(msg, type='success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast '+type+' show';
  setTimeout(()=>t.classList.remove('show'), 3000);
}

// Close modal on overlay click
document.getElementById('detail-modal').addEventListener('click', function(e) {
  if (e.target===this) closeModal();
});

// Enter to add question
document.addEventListener('DOMContentLoaded', () => {
  const qi = document.getElementById('new-question-input');
  if (qi) {
    qi.addEventListener('keydown', e => {
      if (e.key==='Enter' && !e.shiftKey) { e.preventDefault(); addQuestion(); }
    });
  }
});
</script>
