    <!-- GÓI XEM -->
    <div class="form-card">
      <div class="form-card-title">⏳ Gói Xem</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
        <div class="option-card selected" onclick="selectPackage('Hiện Tại', this)">
          <div class="option-check">✓</div>
          <div class="option-icon">🔍</div>
          <div class="option-name">Hiện Tại</div>
          <div class="option-desc">Tình trạng hiện tại</div>
        </div>
        <div class="option-card" onclick="selectPackage('Tương Lai', this)">
          <div class="option-check">✓</div>
          <div class="option-icon">🌠</div>
          <div class="option-name">Tương Lai</div>
          <div class="option-desc">Dự đoán tương lai</div>
        </div>
      </div>
    </div>

    <!-- CÂU HỎI -->
    <div class="form-card">
      <div class="form-card-title">❓ Câu Hỏi Của Bạn</div>
      <div class="question-list" id="question-list"></div>
      <div class="add-question-row">
        <textarea id="new-question-input" placeholder="Nhập câu hỏi bạn muốn hỏi..." rows="2"></textarea>
        <button class="add-q-btn" onclick="addQuestion()">+ Thêm</button>
      </div>
      <div style="font-size: 11px; color: var(--text3); margin-top: 8px;">Thêm tối đa 5 câu hỏi cho buổi xem bài</div>
    </div>

    <button class="submit-btn" id="submit-btn" onclick="submitBooking()">
      🔮 Xác Nhận Đặt Lịch
    </button>
